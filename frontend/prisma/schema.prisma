generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model InternalOrder {
  id        String   @id @default(uuid())
  orderId   String   @unique
  amount    Float
  currency  String   @default("USD")
  status    String   @default("PAID")
  createdAt DateTime @default(now())
}

model GatewayTransaction {
  id             String   @id @default(uuid())
  gatewayTxnId   String   @unique
  gateway        String   // "razorpay", "stripe", "paypal"
  orderRefId     String?
  grossAmount    Float
  feeAmount      Float
  netSettled     Float
  settlementDate DateTime
  status         String   @default("SETTLED")
  createdAt      DateTime @default(now())
}

model ReconciliationResult {
  id             String   @id @default(uuid())
  orderId        String
  gatewayTxnId   String?
  amount         Float
  grossAmount    Float?
  feeAmount      Float?
  netSettled     Float?
  matchStatus    String
  aiExplanation  String?
  createdAt      DateTime @default(now())
}
